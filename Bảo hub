-- ===== HỆ THỐNG ESP MỚI THEO YÊU CẦU =====
local ESPFolder = Instance.new("Folder")
ESPFolder.Name = "ESP"
ESPFolder.Parent = game.CoreGui

local ESPConfig = {
    MonsterESP = false,
    ItemESP = false,
    ShowNames = true,
    ShowDistance = true,
    MonsterColor = Color3.fromRGB(255, 60, 60),
    ItemColor = Color3.fromRGB(80, 255, 80),
}

local function getZombies()
    local zombies = {}
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Model") and v ~= LocalPlayer.Character then
            local hum = v:FindFirstChildWhichIsA("Humanoid")
            local hrp = v:FindFirstChild("HumanoidRootPart")
            if hum and hrp and hum.Health > 0 and not Players:GetPlayerFromCharacter(v) then
                table.insert(zombies, v)
            end
        end
    end
    return zombies
end

local function getItems()
    local items = {}
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("ProximityPrompt") and v.Enabled then
            local model = v:FindFirstAncestorWhichIsA("Model")
            if model and not Players:GetPlayerFromCharacter(model) then
                table.insert(items, v)
            end
        end
    end
    return items
end

local function CreateESPBillboard(part, color, text)
    local billboard = Instance.new("BillboardGui")
    billboard.Adornee = part
    billboard.Size = UDim2.new(0, 200, 0, 45)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = ESPFolder
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.TextColor3 = color
    label.TextSize = 13
    label.Font = Enum.Font.GothamBold
    label.Text = text
    label.Parent = billboard
end

local function ClearESP()
    for _, v in pairs(ESPFolder:GetChildren()) do v:Destroy() end
end

local function UpdateESP()
    ClearESP()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local myPos = char.HumanoidRootPart.Position

    if ESPConfig.MonsterESP then
        for _, zombie in pairs(getZombies()) do
            if zombie.PrimaryPart then
                local dist = math.floor((myPos - zombie.PrimaryPart.Position).Magnitude)
                local text = ""
                if ESPConfig.ShowNames then text = "🧟 " .. zombie.Name end
                if ESPConfig.ShowDistance then text = text .. "\n" .. dist .. " studs" end
                CreateESPBillboard(zombie.PrimaryPart, ESPConfig.MonsterColor, text)
            end
        end
    end

    if ESPConfig.ItemESP then
        for _, prompt in pairs(getItems()) do
            local part = prompt.Parent
            if part and part:IsA("BasePart") then
                local dist = math.floor((myPos - part.Position).Magnitude)
                local text = ""
                if ESPConfig.ShowNames then text = "📦 " .. prompt.ActionText end
                if ESPConfig.ShowDistance then text = text .. "\n" .. dist .. " studs" end
                CreateESPBillboard(part, ESPConfig.ItemColor, text)
            end
        end
    end
end

