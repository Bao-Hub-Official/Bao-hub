-- Kill Aura Loop
task.spawn(function()
    while true do
        task.wait()
        if _G.KillAuraEnabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local root = LocalPlayer.Character.HumanoidRootPart
            for _, monster in pairs(workspace.Monsters:GetChildren()) do
                if monster:FindFirstChild("HumanoidRootPart") then
                    local dist = (root.Position - monster.HumanoidRootPart.Position).Magnitude
                    if dist < (_G.AuraDistance or 25) then
                        ZAP.meleeAttack.fire({monsters = {monster}, civilians = {}, activeSlot = _G.WeaponSlot or 2})
                        break
                    end
                end
            end
        end
    end
end)

-- Stats Loop
task.spawn(function()
    while true do
        task.wait(0.5)
        local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
        if hum then
            if _G.WalkSpeed then hum.WalkSpeed = _G.WalkSpeed end
            if _G.JumpPower then hum.JumpPower = _G.JumpPower end
        end
    end
end)

-- ESP Loop
task.spawn(function()
    while true do
        task.wait(0.5)
        if ESPConfig.MonsterESP or ESPConfig.ItemESP then
            UpdateESP()
        end
    end
end)

